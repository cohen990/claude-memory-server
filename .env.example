# Deployment configuration
# Copy to .env and fill in your values.

# SSH remote for deployment (user@host)
DEPLOY_REMOTE=user@192.168.1.100

# Remote directory where memory-server is installed
DEPLOY_REMOTE_DIR=~/memory-server

# Memory server URL (as seen from the primary machine)
MEMORY_SERVER_URL=http://192.168.1.100:8420
